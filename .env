# =========================
# Shark Work Hub - .env
# =========================

# Server
PORT=3002

# ---------- SQL Server ----------
# لو Windows Auth خلي TRUSTED=1 وسيب USER/PASS فاضي
SHARK_DB_SERVER=EBSITSHARKAWY
SHARK_DB_NAME=SharkWorkHub
SHARK_DB_TRUSTED=1

# لو SQL Auth خلي TRUSTED=0 وحط اليوزر والباس
SHARK_DB_TRUSTED=0
SHARK_DB_USER=sa
SHARK_DB_PASS=StrongP@ss123

# ---------- Email (SMTP) ----------
# Gmail example:
SHARK_SMTP_HOST=smtp.gmail.com
SHARK_SMTP_PORT=587
SHARK_SMTP_USER=YOUR@gmail.com
SHARK_SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

SHARK_MAIL_FROM=YOUR@gmail.com
SHARK_MAIL_TO=YOUR@gmail.com

# ---------- Reminders ----------
# قبل الديدلاين بكام ساعة يبعت
SHARK_REMINDER_HOURS_BEFORE=24

# كل كام دقيقة يشيك على الريمايندر
SHARK_CRON_MINUTES=5